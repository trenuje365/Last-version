{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "../tmp/nt-batch",
    "rootDir": "..",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "noEmitOnError": false
  },
  "include": [
    "../scripts/nt-batch.ts"
  ],
  "exclude": [
    "../components/**",
    "../context/**",
    "../resources/ClubLogoAssets.ts",
    "../resources/PlayerCardAssets.ts",
    "../**/*reference*",
    "../**/*copy*"
  ]
}
